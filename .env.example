NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://127.0.0.1:5173
DATABASE_URL=postgres://ai_war_room:ai_war_room@127.0.0.1:5432/ai_war_room
REDIS_URL=redis://127.0.0.1:6379
APP_ENCRYPTION_KEY=local-development-encryption-key-change-me
IDEMPOTENCY_TTL_SECONDS=86400
LLM_PRIMARY_PROVIDER=mock
LLM_FALLBACK_PROVIDER=mock
LLM_PRIMARY_MODEL=mock-json-v1
LLM_FALLBACK_MODEL=mock-json-v1
LLM_MAX_ATTEMPTS=3
LLM_REQUEST_TIMEOUT_MS=30000
# Outside production, set true only when you intentionally want Anthropic/OpenAI calls.
LLM_ALLOW_REAL_PROVIDERS=false

# Optional real provider keys. Keep actual secrets in local .env only.
# .env files are ignored by git.
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
RESEARCH_PROVIDER=mock
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_MAX_RESULTS=5

# Temporal workflow start/status integration. Keep disabled unless a Temporal server and worker are running.
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-war-room-runs

# Frontend runtime preference: auto (default), true, or false.
# auto uses Temporal when the API reports TEMPORAL_ENABLED=true.
VITE_USE_TEMPORAL_WORKFLOWS=auto
# Max time the frontend will poll Temporal workflow status before offering resume (milliseconds).
VITE_TEMPORAL_OBSERVATION_TIMEOUT_MS=300000

# Temporal workflow SSE poll interval and max stream duration on the API (milliseconds).
TEMPORAL_WORKFLOW_STREAM_POLL_MS=1000
TEMPORAL_WORKFLOW_STREAM_TIMEOUT_MS=300000

# Auth provider rollout (headers, bearer, session, external).
AUTH_PROVIDER=headers
AUTH_BEARER_TOKEN=
AUTH_SESSION_TTL_SECONDS=86400
AUTH_EXTERNAL_VENDOR=clerk
AUTH_EXTERNAL_ADAPTER=mock
AUTH_EXTERNAL_JWT_SECRET=
AUTH_EXTERNAL_JWKS_URL=
AUTH_EXTERNAL_ISSUER=ai-war-room-external-auth
AUTH_EXTERNAL_AUDIENCE=ai-war-room-api
AUTH_EXTERNAL_AUTO_PROVISION=true

# Stripe billing activation. Keep disabled locally unless testing checkout flows.
STRIPE_ENABLED=false
STRIPE_BILLING_ADAPTER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_SUCCESS_URL=http://127.0.0.1:5173/billing/success
STRIPE_CANCEL_URL=http://127.0.0.1:5173/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://127.0.0.1:5173/billing/portal
STRIPE_METERED_USAGE_ENABLED=false
STRIPE_METER_EVENT_NAME=
BILLING_NOTIFICATION_ADAPTER=mock
BILLING_NOTIFICATION_RECIPIENT=
