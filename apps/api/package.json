{
  "name": "@ai-war-room/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/main.js",
    "dev:watch": "tsx watch src/main.ts",
    "db:migrate": "npm run build && node dist/db/migrate.js",
    "eval:prompts": "tsx src/evaluation/run-prompt-evaluation.ts",
    "start": "node dist/main.js",
    "worker:temporal": "npm run build && node dist/temporal/temporal.worker.js",
    "worker:temporal:dev": "tsx src/temporal/temporal.worker.ts",
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@temporalio/activity": "^1.19.0",
    "@temporalio/client": "^1.19.0",
    "@temporalio/worker": "^1.19.0",
    "@temporalio/workflow": "^1.19.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ai-war-room/schemas": "0.0.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@opentelemetry/api": "^1.9.1",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  }
}
